# F1Predict configuration (env_prefix F1P_). Copy to .env and adjust for your environment.
# Everything has a sane default in app/config.py; you only need to set what differs.

# --- API ---
F1P_ENVIRONMENT=production
# JSON list of allowed CORS origins (your deployed web origin).
F1P_CORS_ORIGINS=["https://f1predict.example.com"]

# --- Database (the engine runs on the committed Parquet artifacts; DB is for future use) ---
# The compose files build POSTGRES_PASSWORD and F1P_DATABASE_URL from F1P_DB_PASSWORD,
# so set a strong, unique value here (the compose `up` fails fast if it is unset). Do NOT
# commit a real password — this template only names the variable.
F1P_DB_PASSWORD=change-me-to-a-long-random-string
# Override the full URL only if your DB user/host/name differ from the compose defaults.
# F1P_DATABASE_URL=postgresql+psycopg://f1predict:${F1P_DB_PASSWORD}@db:5432/f1predict

# --- Data / ETL ---
F1P_FASTF1_CACHE_DIR=.cache/fastf1

# --- Post-race auto-refresh (in-app weekly scheduler -> app.etl.refresh) ---
# OFF by default. Enable in production to pull new races + recalibrate after each weekend.
# Refreshes laps/practice, hazard cache, overtaking proxies, tyre degradation, and the
# Polymarket fallback snapshot (commits only if tests stay green via the GitHub Action).
F1P_REFRESH_ENABLED=false
F1P_REFRESH_DAY_OF_WEEK=mon
F1P_REFRESH_HOUR=6

# --- Live CLOB WebSocket price feed (live pricing v2) ---
# OFF by default -> /markets/live does an on-demand REST order-book fetch. ON -> a background
# task streams the upcoming race's order books; /markets/live + /markets/stream (SSE) then
# serve always-fresh top-of-book prices with no per-request REST round-trip.
F1P_LIVE_WS_ENABLED=false
